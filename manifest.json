{
  "manifest_version":3,
  "name":"Universal WebGL Extractor",
  "version":"0.1.0",
  "permissions":["activeTab","scripting"],
  "host_permissions":["<all_urls>"],
  "action":{"default_popup":"popup/popup.html"},
  "content_scripts":[{"matches":["<all_urls>"],"js":["inject/injector.js"],"run_at":"document_start"}],
  "web_accessible_resources":[{"resources": [
    "inject/*",
    "export/*"
],"matches":["<all_urls>"]}]
}
